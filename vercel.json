{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "env": {
    "MEDIA_PUBLIC_BASE_URL": "https://lauralian-collection.oss-cn-hongkong.aliyuncs.com",
    "OSS_PUBLIC_BASE_URL": "https://lauralian-collection.oss-cn-hongkong.aliyuncs.com",
    "SITE_CONTENT_PUBLIC_URL": "https://lauralian-collection.oss-cn-hongkong.aliyuncs.com/data/site-content.json",
    "SITE_CONTENT_REMOTE_ENABLED": "1"
  },
  "builds": [
    {
      "src": "public/**/*.php",
      "use": "vercel-php@0.7.2",
      "config": {
        "includeFiles": [
          "data/**"
        ],
        "excludeFiles": [
          "public/uploads/**",
          "uploads/**",
          "**/*.mp4",
          "**/*.mov",
          "**/*.avi",
          "**/*.mkv",
          "**/*.webm"
        ]
      }
    },
    {
      "src": "public/assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/uploads/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/([A-Za-z0-9_-]+\\.php)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
