{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "public/**/*.php",
      "use": "vercel-php@0.7.2",
      "config": {
        "includeFiles": [
          "data/**"
        ]
      }
    },
    {
      "src": "public/assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/uploads/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/([A-Za-z0-9_-]+\\.php)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
