{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "public/**/*.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "data/**",
      "excludeFiles": "{public/uploads/**,uploads/**,**/*.mp4,**/*.mov,**/*.avi,**/*.mkv,**/*.webm,**/*.jpg,**/*.jpeg,**/*.png,**/*.gif}"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/([A-Za-z0-9_-]+\\.php)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
