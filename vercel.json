{
  "version": 2,
  "functions": {
    "public/**/*.php": {
      "includeFiles": "data/**",
      "excludeFiles": "{public/uploads/**,uploads/**,**/*.mp4,**/*.mov,**/*.avi,**/*.mkv,**/*.webm,**/*.jpg,**/*.jpeg,**/*.png,**/*.gif}"
    }
  },
  "builds": [
    {
      "src": "public/**/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "public/assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/uploads/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/([A-Za-z0-9_-]+\\.php)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
